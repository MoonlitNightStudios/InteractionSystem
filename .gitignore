# ==========================================
# Unreal Engine 5 Plugin .gitignore Template
# ==========================================

# Ignore engine-generated compilation & build folders
Binaries/
Intermediate/
Saved/
DerivedDataCache/

# Ignore project-level artifacts generated if you test the plugin locally
/Build/

# Ignore IDE and user-specific workspace configurations
.vs/
.idea/
.vscode/
*.sln
*.suo
*.xcworkspace
*.xcodeproj
*.DotSettings.user
*.code-workspace

# Ignore operating system temporary files
Thumbs.db
.DS_Store

# Ignore compiled script and object files
*.bak
*.log
*.obj
*.pdb
*.ilk
*.exp
